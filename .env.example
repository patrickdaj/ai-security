# Copy to .env and fill in. .env is gitignored.

# --- Backend selection ------------------------------------------------------
# Which model provider the augmentation layer uses: "anthropic" (default) or
# "ollama" (local). Claude is what the modules are tuned for; Ollama keeps
# sensitive artifacts (code, secrets, IAM graphs) on-prem at some quality cost.
AUG_BACKEND=anthropic

# --- Anthropic (Claude) backend ---------------------------------------------
# Required when AUG_BACKEND=anthropic.
ANTHROPIC_API_KEY=sk-ant-...
# Most capable; default for judgment-heavy triage.
AUG_MODEL=claude-opus-4-8
# Cheap, high-volume classification (used when a call passes fast=True).
AUG_FAST_MODEL=claude-haiku-4-5

# --- Ollama (local) backend -------------------------------------------------
# Used when AUG_BACKEND=ollama. Pick a model that follows JSON/tool
# instructions well (llama3.1, qwen2.5, mistral-nemo); smaller models give
# weaker security judgments and may fail schema validation.
AUG_OLLAMA_MODEL=llama3.1
# Optional faster/smaller local model for fast=True calls. Defaults to AUG_OLLAMA_MODEL.
# AUG_OLLAMA_FAST_MODEL=llama3.2
# Optional: point at a remote Ollama daemon (else 127.0.0.1:11434).
# AUG_OLLAMA_HOST=http://127.0.0.1:11434
# Optional: enable thinking on models that support it (qwen3, deepseek-r1).
# AUG_OLLAMA_THINK=1
