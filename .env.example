# Copy to .env and fill in. .env is gitignored.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model used by the augmentation layer.
# Defaults to claude-opus-4-8 (most capable). Use claude-sonnet-4-6 for
# high-volume triage where cost matters, or claude-haiku-4-5 for cheap
# classification.
AUG_MODEL=claude-opus-4-8

# Optional: model used for cheap, high-volume classification passes.
AUG_FAST_MODEL=claude-haiku-4-5
